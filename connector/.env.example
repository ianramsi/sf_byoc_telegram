# ============================================================================
# BYOC Telegram Connector — environment template
# Copy to `.env` and fill in your own values. NEVER commit the real .env.
# ============================================================================

# --- Salesforce OAuth & instance ---
SF_CONSUMER_KEY=<Connected App / External Client App consumer key>
SF_INSTANCE_URL=https://<mydomain>.sandbox.my.salesforce.com
# Note the -scrt host! Interaction Service lives here, not on the normal My Domain.
SF_SCRT_INSTANCE_URL=https://<mydomain>.sandbox.my.salesforce-scrt.com
SF_AUDIENCE=https://test.salesforce.com          # https://login.salesforce.com for prod
SF_AUTH_ENDPOINT=https://test.salesforce.com/services/oauth2/token
SF_SUBJECT=<integration username, e.g. integration@yourcompany.com.sandboxname>

# Private key for JWT signing (RS256) — the full PEM content on ONE line with \n escapes:
# -----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----
SF_PRIVATE_KEY=<contents of server.key, \n-escaped on one line>

# ⚠️ GOTCHA: must be the 15-CHARACTER org ID (not 18-char), and the variable
# name must be SF_ORG_ID exactly. 18-char form -> Interaction Service rejects
# every call with {"message":"Enter a valid header.","code":10016}.
SF_ORG_ID=<15-char org id, e.g. 00Dxxxxxxxxxxxx>

# ⚠️ GOTCHA: must be the ConversationChannelDefinition DeveloperName, exactly.
SF_AUTHORIZATION_CONTEXT=BYOC_ChannelDefinition1

# --- BYOC channel ---
# UUID from the MessagingChannel detail page (Setup -> Messaging Settings -> your channel)
CHANNEL_ADDRESS_IDENTIFIER=<uuid>
# Any stable string identifying the end user (e.g. your bot username)
END_USER_CLIENT_IDENTIFIER=<your_bot_name>

# --- Telegram ---
TELEGRAM_BOT_TOKEN=<token from @BotFather>
# Random 64-hex string; pass the same value as secret_token when calling setWebhook.
TELEGRAM_WEBHOOK_SECRET=<random 64 hex chars>

# --- Pub/Sub + misc ---
SF_PUB_SUB_ENDPOINT=api.pubsub.salesforce.com:7443
SF_PUB_SUB_EVENT_RECEIVE_LIMIT=100
IS_LOCAL_CONFIG=true
API_VERSION=63.0
ROUTING_OWNER=Salesforce      # must match the CCD's routingOwner
AUTO_CREATE_AGENT_WORK=false  # true only if routingOwner=Partner
PORT=3000
SERVER_PORT=3000

# --- n8n integration ---
# Shared secret for the connector's /api/escalate endpoint (n8n -> connector).
# Must equal CONNECTOR_SECRET in the n8n workflow (or its httpHeaderAuth credential).
N8N_CONNECTOR_SECRET=<random 64 hex chars>
# n8n reset webhook (connector -> n8n) called when an agent ends the chat (CDC).
N8N_RESET_WEBHOOK_URL=https://<your-n8n-host>/webhook/byoc-telegram-reset
